-- ============================================================
-- RYAN GAMES v8 — Sistema Social Completo
-- Execute no SQL Editor do Supabase
-- ============================================================

-- ── 1. ATUALIZA PROFILES (adiciona status online) ───────────
ALTER TABLE public.profiles
  ADD COLUMN IF NOT EXISTS display_name TEXT,
  ADD COLUMN IF NOT EXISTS status       TEXT DEFAULT 'offline',  -- online | away | offline
  ADD COLUMN IF NOT EXISTS last_seen    TIMESTAMPTZ DEFAULT NOW();

-- ── 2. AMIZADES ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.friendships (
  id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  requester   UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  addressee   UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  status      TEXT NOT NULL DEFAULT 'pending', -- pending | accepted | blocked
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  UNIQUE(requester, addressee),
  CHECK (requester <> addressee)
);

CREATE INDEX IF NOT EXISTS friendships_requester_idx ON public.friendships(requester);
CREATE INDEX IF NOT EXISTS friendships_addressee_idx ON public.friendships(addressee);
CREATE INDEX IF NOT EXISTS friendships_status_idx    ON public.friendships(status);

ALTER TABLE public.friendships ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Usuário vê suas próprias amizades"
  ON public.friendships FOR SELECT
  USING (auth.uid() = requester OR auth.uid() = addressee);

CREATE POLICY "Usuário envia pedido de amizade"
  ON public.friendships FOR INSERT
  WITH CHECK (auth.uid() = requester);

CREATE POLICY "Usuário atualiza suas amizades"
  ON public.friendships FOR UPDATE
  USING (auth.uid() = requester OR auth.uid() = addressee);

CREATE POLICY "Usuário remove suas amizades"
  ON public.friendships FOR DELETE
  USING (auth.uid() = requester OR auth.uid() = addressee);

-- View para buscar amigos aceitos facilmente
CREATE OR REPLACE VIEW public.friends_view AS
SELECT
  f.id,
  f.status,
  f.created_at,
  CASE WHEN f.requester = auth.uid() THEN f.addressee ELSE f.requester END AS friend_id
FROM public.friendships f
WHERE (f.requester = auth.uid() OR f.addressee = auth.uid())
  AND f.status = 'accepted';

-- ── 3. CANAIS (DM + Grupos) ──────────────────────────────────
CREATE TABLE IF NOT EXISTS public.channels (
  id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  type        TEXT NOT NULL DEFAULT 'dm',  -- dm | group
  name        TEXT,                         -- só grupos têm nome
  description TEXT,
  icon        TEXT DEFAULT '💬',
  owner_id    UUID REFERENCES auth.users(id) ON DELETE SET NULL,
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

ALTER TABLE public.channels ENABLE ROW LEVEL SECURITY;

-- ── 4. MEMBROS DOS CANAIS ────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.channel_members (
  id         UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  channel_id UUID NOT NULL REFERENCES public.channels(id) ON DELETE CASCADE,
  user_id    UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  role       TEXT NOT NULL DEFAULT 'member', -- owner | admin | member
  joined_at  TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  UNIQUE(channel_id, user_id)
);

CREATE INDEX IF NOT EXISTS channel_members_channel_idx ON public.channel_members(channel_id);
CREATE INDEX IF NOT EXISTS channel_members_user_idx    ON public.channel_members(user_id);

ALTER TABLE public.channel_members ENABLE ROW LEVEL SECURITY;

-- Usuário vê canais que participa
CREATE POLICY "Membro vê seus canais"
  ON public.channel_members FOR SELECT
  USING (auth.uid() = user_id);

CREATE POLICY "Membro entra em canal"
  ON public.channel_members FOR INSERT
  WITH CHECK (auth.uid() = user_id);

CREATE POLICY "Membro sai de canal"
  ON public.channel_members FOR DELETE
  USING (auth.uid() = user_id);

-- Canais: só membros veem
CREATE POLICY "Membros veem o canal"
  ON public.channels FOR SELECT
  USING (
    EXISTS (
      SELECT 1 FROM public.channel_members
      WHERE channel_id = channels.id AND user_id = auth.uid()
    )
  );

CREATE POLICY "Qualquer usuário cria canal"
  ON public.channels FOR INSERT
  WITH CHECK (auth.uid() = owner_id);

CREATE POLICY "Dono atualiza canal"
  ON public.channels FOR UPDATE
  USING (auth.uid() = owner_id);

-- ── 5. MENSAGENS ─────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS public.messages (
  id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  channel_id  UUID NOT NULL REFERENCES public.channels(id) ON DELETE CASCADE,
  sender_id   UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  content     TEXT NOT NULL CHECK (char_length(content) <= 1000),
  edited      BOOLEAN NOT NULL DEFAULT FALSE,
  created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS messages_channel_idx    ON public.messages(channel_id);
CREATE INDEX IF NOT EXISTS messages_created_at_idx ON public.messages(created_at DESC);

ALTER TABLE public.messages ENABLE ROW LEVEL SECURITY;

-- Só membros do canal leem mensagens
CREATE POLICY "Membros leem mensagens do canal"
  ON public.messages FOR SELECT
  USING (
    EXISTS (
      SELECT 1 FROM public.channel_members
      WHERE channel_id = messages.channel_id AND user_id = auth.uid()
    )
  );

CREATE POLICY "Membros enviam mensagens"
  ON public.messages FOR INSERT
  WITH CHECK (
    auth.uid() = sender_id AND
    EXISTS (
      SELECT 1 FROM public.channel_members
      WHERE channel_id = messages.channel_id AND user_id = auth.uid()
    )
  );

CREATE POLICY "Autor edita/deleta mensagem"
  ON public.messages FOR DELETE
  USING (auth.uid() = sender_id);

-- ── 6. TYPING INDICATORS (efêmero — sem RLS pesado) ─────────
CREATE TABLE IF NOT EXISTS public.typing_indicators (
  channel_id UUID NOT NULL REFERENCES public.channels(id) ON DELETE CASCADE,
  user_id    UUID NOT NULL REFERENCES auth.users(id) ON DELETE CASCADE,
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  PRIMARY KEY (channel_id, user_id)
);

ALTER TABLE public.typing_indicators ENABLE ROW LEVEL SECURITY;

CREATE POLICY "Membros veem quem está digitando"
  ON public.typing_indicators FOR SELECT USING (TRUE);

CREATE POLICY "Usuário atualiza próprio typing"
  ON public.typing_indicators FOR INSERT WITH CHECK (auth.uid() = user_id);

CREATE POLICY "Usuário atualiza próprio typing update"
  ON public.typing_indicators FOR UPDATE USING (auth.uid() = user_id);

CREATE POLICY "Usuário remove próprio typing"
  ON public.typing_indicators FOR DELETE USING (auth.uid() = user_id);

-- ── 7. FUNÇÃO: criar DM entre dois usuários ──────────────────
CREATE OR REPLACE FUNCTION public.get_or_create_dm(other_user_id UUID)
RETURNS UUID AS $$
DECLARE
  v_channel_id UUID;
BEGIN
  -- Busca DM existente entre os dois
  SELECT cm1.channel_id INTO v_channel_id
  FROM public.channel_members cm1
  JOIN public.channel_members cm2 ON cm1.channel_id = cm2.channel_id
  JOIN public.channels c ON c.id = cm1.channel_id
  WHERE cm1.user_id = auth.uid()
    AND cm2.user_id = other_user_id
    AND c.type = 'dm';

  -- Se não existe, cria
  IF v_channel_id IS NULL THEN
    INSERT INTO public.channels (type, owner_id)
    VALUES ('dm', auth.uid())
    RETURNING id INTO v_channel_id;

    INSERT INTO public.channel_members (channel_id, user_id, role) VALUES
      (v_channel_id, auth.uid(), 'member'),
      (v_channel_id, other_user_id, 'member');
  END IF;

  RETURN v_channel_id;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- ── 8. FUNÇÃO: atualizar status online ───────────────────────
CREATE OR REPLACE FUNCTION public.update_user_status(p_status TEXT)
RETURNS VOID AS $$
BEGIN
  UPDATE public.profiles
  SET status = p_status, last_seen = NOW()
  WHERE id = auth.uid();
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- ── 9. HABILITAR REALTIME nas tabelas importantes ────────────
-- Execute esses comandos no Supabase → Database → Replication
-- Ou cole abaixo se tiver acesso:
ALTER PUBLICATION supabase_realtime ADD TABLE public.messages;
ALTER PUBLICATION supabase_realtime ADD TABLE public.typing_indicators;
ALTER PUBLICATION supabase_realtime ADD TABLE public.friendships;
ALTER PUBLICATION supabase_realtime ADD TABLE public.profiles;
